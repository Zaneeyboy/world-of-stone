rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public catalog — anyone can read products, projects, and promotions
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /projects/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /promotions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
